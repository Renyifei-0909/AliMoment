<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="Infinity" maxWidth="Infinity" styleClass="material-root" stylesheets="@../styles/app.css" xmlns="http://javafx.com/javafx/11.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aiimoment.controller.MaterialPageController">
    <HBox spacing="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <VBox minWidth="220.0" prefWidth="220.0" styleClass="material-sidebar">
            <Button fx:id="addMaterialBtn" mnemonicParsing="false" styleClass="material-add-btn" text="+ 添加素材" />
            <Label styleClass="material-section-title" text="素材分类" />
            <VBox spacing="6.0">
                <Button fx:id="allBtn" mnemonicParsing="false" styleClass="material-filter-btn material-filter-btn-active" text="全部素材" />
                <Button fx:id="videoBtn" mnemonicParsing="false" styleClass="material-filter-btn" text="视频" />
                <Button fx:id="imageBtn" mnemonicParsing="false" styleClass="material-filter-btn" text="图片" />
                <Button fx:id="audioBtn" mnemonicParsing="false" styleClass="material-filter-btn" text="音频" />
                <Button fx:id="textBtn" mnemonicParsing="false" styleClass="material-filter-btn" text="文本" />
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
        </VBox>

        <VBox styleClass="material-main" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" styleClass="material-toolbar">
                <TextField fx:id="searchField" promptText="搜索素材..." styleClass="material-search-field" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="6.0">
                    <Button fx:id="gridViewBtn" mnemonicParsing="false" styleClass="material-view-btn material-view-btn-active" text="网格" />
                    <Button fx:id="listViewBtn" mnemonicParsing="false" styleClass="material-view-btn" text="列表" />
                </HBox>
            </HBox>

            <ScrollPane fx:id="contentScrollPane" fitToWidth="true" hbarPolicy="NEVER" styleClass="material-scroll" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
                <StackPane styleClass="material-content-shell">
                    <FlowPane fx:id="gridPane" hgap="12.0" prefWrapLength="980.0" vgap="12.0" />
                    <VBox fx:id="listBox" managed="false" spacing="10.0" visible="false" />
                    <Label fx:id="emptyStateLabel" managed="false" styleClass="material-empty-state" text="没有符合条件的素材" visible="false" />
                </StackPane>
            </ScrollPane>
        </VBox>
    </HBox>
</AnchorPane>