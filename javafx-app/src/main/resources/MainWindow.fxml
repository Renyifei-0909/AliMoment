<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/11.0.2" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.aiimoment.controller.MainController" styleClass="root-shell" stylesheets="@styles/app.css">

    <top>
        <VBox spacing="0">
            <BorderPane fx:id="topChrome" minHeight="56" styleClass="top-bar">
                <left>
                    <HBox alignment="CENTER_LEFT" spacing="14">
                        <StackPane fx:id="brandLogoContainer" maxHeight="48" maxWidth="48" minHeight="48" minWidth="48" />
                        <Label styleClass="brand-name" text="Alimoment" />
                        <Button fx:id="navMenuBtn" mnemonicParsing="false" styleClass="menu-chevron-btn" text="菜单  ▾" />
                    </HBox>
                </left>
                <center>
                    <HBox fx:id="navItemsContainer" alignment="CENTER" spacing="4">
                        <Button fx:id="navMaterial" contentDisplay="TOP" mnemonicParsing="false" styleClass="nav-tab-btn" text="素材库">
                            <graphic>
                                <Label styleClass="nav-tab-icon" text="📁" />
                            </graphic>
                        </Button>
                        <Button fx:id="navDraft" contentDisplay="TOP" mnemonicParsing="false" styleClass="nav-tab-btn" text="草稿箱">
                            <graphic>
                                <Label styleClass="nav-tab-icon" text="🗑" />
                            </graphic>
                        </Button>
                        <Button fx:id="navSearch" contentDisplay="TOP" mnemonicParsing="false" styleClass="nav-tab-btn" text="智能检索">
                            <graphic>
                                <Label styleClass="nav-tab-icon" text="🔍" />
                            </graphic>
                        </Button>
                        <Button fx:id="navSmartEdit" contentDisplay="TOP" mnemonicParsing="false" styleClass="nav-tab-btn" text="智能剪辑">
                            <graphic>
                                <Label styleClass="nav-tab-icon" text="✂" />
                            </graphic>
                        </Button>
                        <Button fx:id="navSettings" contentDisplay="TOP" mnemonicParsing="false" styleClass="nav-tab-btn" text="设置">
                            <graphic>
                                <Label styleClass="nav-tab-icon" text="⚙" />
                            </graphic>
                        </Button>
                    </HBox>
                </center>
                <right>
                    <HBox fx:id="windowControls" alignment="CENTER_RIGHT" spacing="4">
                        <Button fx:id="minimizeBtn" contentDisplay="GRAPHIC_ONLY" mnemonicParsing="false" styleClass="win-ctrl-btn">
                            <graphic>
                                <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@images/p1.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button fx:id="maximizeBtn" contentDisplay="GRAPHIC_ONLY" mnemonicParsing="false" styleClass="win-ctrl-btn">
                            <graphic>
                                <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@images/p2.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                        <Button fx:id="closeBtn" contentDisplay="GRAPHIC_ONLY" mnemonicParsing="false" styleClass="win-ctrl-btn">
                            <graphic>
                                <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@images/p3.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>
                    </HBox>
                </right>
            </BorderPane>
        </VBox>
    </top>

    <center>
        <AnchorPane fx:id="contentArea" styleClass="app-content-area">
            <AnchorPane fx:id="pageMaterial" visible="false" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" />
            <AnchorPane fx:id="pageDraft" visible="false" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" />
            <AnchorPane fx:id="pageSearch" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" />
            <AnchorPane fx:id="pageSmartEdit" visible="false" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" />
            <AnchorPane fx:id="pageSettings" visible="false" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" />
        </AnchorPane>
    </center>
</BorderPane>
