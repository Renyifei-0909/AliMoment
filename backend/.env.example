# PC-Net runtime assets are external to this repo.
# Point these values to the already prepared server-side deployment.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=alimoment

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_PUBLIC_BASE_URL=http://127.0.0.1:8000

PCNET_ROOT=/Disks/8TDisk/xtx/AliMoment/PC-Net
PCNET_CONFIG_PATH=/Disks/8TDisk/xtx/AliMoment/PC-Net/config/activitynet/main_train_test.json
PCNET_CHECKPOINT_PATH=/Disks/8TDisk/xtx/AliMoment/PC-Net/checkpoints/ActivityNet/8_2025-05-14_14-07-12/model-best.pt
PCNET_FEATURE_PATH=/Disks/8TDisk/xtx/AliMoment/PC-Net/data/activitynet/sub_activitynet_v1-3.c3d.hdf5
PCNET_DEVICE=cuda:0
PCNET_TOP_K=5
PCNET_VOTE=false
PCNET_SEED=8

DEMO_ASSETS_MANIFEST_PATH=/Disks/8TDisk/xtx/AliMoment/backend/app/demo_assets/assets.json
STORAGE_ROOT=/Disks/8TDisk/xtx/AliMoment/backend/storage
STORAGE_INPUTS_DIR=/Disks/8TDisk/xtx/AliMoment/backend/storage/inputs
STORAGE_FEATURES_DIR=/Disks/8TDisk/xtx/AliMoment/backend/storage/features
STORAGE_OUTPUTS_DIR=/Disks/8TDisk/xtx/AliMoment/backend/storage/outputs

QUERY_NORMALIZER_MODE=hybrid
LLM_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=10
